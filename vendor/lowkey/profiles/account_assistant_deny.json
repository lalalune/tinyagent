{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenySecretValues",
      "Effect": "Deny",
      "Action": [
        "secretsmanager:GetSecretValue",
        "secretsmanager:GetResourcePolicy"
      ],
      "Resource": "*"
    },
    {
      "Sid": "DenyS3ObjectAccess",
      "Effect": "Deny",
      "Action": [
        "s3:GetObject",
        "s3:GetObjectVersion",
        "s3:GetObjectAcl"
      ],
      "Resource": "*"
    },
    {
      "Sid": "DenyLambdaCodeAccess",
      "Effect": "Deny",
      "Action": [
        "lambda:GetFunction"
      ],
      "Resource": "*"
    }
  ]
}
