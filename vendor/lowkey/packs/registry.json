{
  "version": 1,
  "defaults": {
    "ami_filter": "al2023-ami-*-arm64",
    "arch": "arm64",
    "os": "al2023",
    "instance_type": "t4g.xlarge",
    "root_volume_gb": 40,
    "data_volume_gb": 80,
    "bedrock_region": "us-east-1"
  },
  "packs": {
    "bedrockify": {
      "type": "base",
      "description": "OpenAI-compatible Bedrock proxy (systemd daemon on localhost)",
      "order": 0
    },
    "claude-code": {
      "type": "agent",
      "description": "Claude Code — Anthropic's coding agent with native Bedrock support",
      "deps": [],
      "instance_type": "t4g.large",
      "root_volume_gb": 40,
      "data_volume_gb": 0,
      "default_model": "us.anthropic.claude-sonnet-4-6",
      "ports": {},
      "brain": false,
      "claude_code": false,
      "experimental": false
    },
    "openclaw": {
      "type": "agent",
      "description": "OpenClaw — stateful AI agent with persistent gateway",
      "deps": [
        "bedrockify"
      ],
      "instance_type": "t4g.xlarge",
      "root_volume_gb": 40,
      "data_volume_gb": 80,
      "default_model": "us.anthropic.claude-opus-4-6-v1",
      "ports": {
        "gateway": 3001
      },
      "brain": true,
      "claude_code": false,
      "experimental": false
    },
    "hermes": {
      "type": "agent",
      "description": "Hermes — NousResearch CLI agent via bedrockify (experimental)",
      "deps": [
        "bedrockify"
      ],
      "instance_type": "t4g.medium",
      "root_volume_gb": 40,
      "data_volume_gb": 0,
      "default_model": "global.anthropic.claude-opus-4-6-v1",
      "ports": {},
      "brain": false,
      "claude_code": false,
      "experimental": true
    },
    "pi": {
      "type": "agent",
      "description": "Pi — minimal terminal coding harness (experimental)",
      "deps": [
        "bedrockify"
      ],
      "instance_type": "t4g.medium",
      "root_volume_gb": 40,
      "data_volume_gb": 0,
      "default_model": "us.anthropic.claude-sonnet-4-6-v1",
      "ports": {},
      "brain": false,
      "claude_code": false,
      "experimental": true
    },
    "ironclaw": {
      "type": "agent",
      "description": "IronClaw — Rust-based AI agent by NEAR AI (experimental)",
      "deps": [
        "bedrockify"
      ],
      "instance_type": "t4g.medium",
      "root_volume_gb": 40,
      "data_volume_gb": 0,
      "default_model": "us.anthropic.claude-sonnet-4-6-v1",
      "ports": {},
      "brain": false,
      "claude_code": false,
      "experimental": true
    },
    "nemoclaw": {
      "type": "agent",
      "description": "NemoClaw — OpenClaw in sandboxed OpenShell with Bedrock inference",
      "deps": [
        "bedrockify"
      ],
      "instance_type": "t4g.xlarge",
      "root_volume_gb": 40,
      "data_volume_gb": 80,
      "default_model": "us.anthropic.claude-sonnet-4-6",
      "ports": {},
      "brain": true,
      "claude_code": false,
      "experimental": true,
      "requires_docker": true,
      "compatible_profiles": [
        "personal_assistant"
      ]
    },
    "kiro-cli": {
      "type": "agent",
      "description": "Kiro CLI v2 — AWS agentic IDE terminal client with MCP server support (experimental, headless mode available via --kiro-api-key)",
      "deps": [],
      "instance_type": "t4g.medium",
      "root_volume_gb": 40,
      "data_volume_gb": 0,
      "ports": {},
      "brain": false,
      "claude_code": false,
      "experimental": true
    },
    "codex-cli": {
      "type": "agent",
      "description": "Codex CLI — OpenAI's coding agent (builder profile, authenticate post-deploy)",
      "deps": [],
      "instance_type": "t4g.medium",
      "root_volume_gb": 40,
      "data_volume_gb": 0,
      "default_model": "gpt-5.4",
      "ports": {},
      "brain": false,
      "claude_code": false,
      "experimental": true,
      "requires_openai_key": true
    },
    "roundhouse": {
      "type": "agent",
      "description": "Roundhouse — AI coding agent with Telegram channel (pi-based)",
      "deps": [],
      "instance_type": "t4g.medium",
      "root_volume_gb": 40,
      "data_volume_gb": 0,
      "default_model": "us.anthropic.claude-opus-4-6-v1",
      "ports": {},
      "brain": false,
      "claude_code": false,
      "experimental": false,
      "requires_telegram_token": true,
      "compatible_profiles": [
        "builder"
      ]
    }
  }
}
