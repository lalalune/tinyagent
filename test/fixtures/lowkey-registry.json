{
  "version": 1,
  "defaults": {
    "arch": "arm64",
    "os": "al2023",
    "root_volume_gb": 40,
    "data_volume_gb": 80
  },
  "packs": {
    "bedrockify": {
      "type": "base",
      "description": "OpenAI-compatible Bedrock proxy (systemd daemon on localhost)",
      "ports": {}
    },
    "claude-code": {
      "type": "agent",
      "description": "Claude Code — Anthropic's coding agent with native Bedrock support",
      "deps": [],
      "data_volume_gb": 0,
      "default_model": "us.anthropic.claude-sonnet-4-6",
      "ports": {},
      "brain": false
    },
    "openclaw": {
      "type": "agent",
      "description": "OpenClaw — stateful AI agent with persistent gateway",
      "deps": ["bedrockify"],
      "data_volume_gb": 80,
      "default_model": "us.anthropic.claude-opus-4-6-v1",
      "ports": {
        "gateway": 3001
      },
      "brain": true
    },
    "codex-cli": {
      "type": "agent",
      "description": "Codex CLI — OpenAI's coding agent",
      "deps": [],
      "data_volume_gb": 0,
      "default_model": "gpt-5.4",
      "ports": {},
      "brain": false,
      "requires_openai_key": true,
      "compatible_profiles": ["headless", "interactive-cli"]
    },
    "kiro-cli": {
      "type": "agent",
      "description": "Kiro — interactive coding agent CLI",
      "deps": [],
      "data_volume_gb": 0,
      "default_model": "gpt-5.4",
      "ports": {},
      "brain": false,
      "interactive_only": true,
      "compatible_profiles": ["interactive-cli"]
    },
    "ironclaw": {
      "type": "agent",
      "description": "IronClaw — Rust-based AI agent by NEAR AI",
      "deps": ["bedrockify"],
      "data_volume_gb": 0,
      "ports": {},
      "brain": false,
      "experimental": true,
      "requires_postgres": true,
      "requires_systemd": true
    },
    "nemoclaw": {
      "type": "agent",
      "description": "NemoClaw — OpenClaw in sandboxed OpenShell with Bedrock inference",
      "deps": ["bedrockify"],
      "data_volume_gb": 80,
      "ports": {},
      "brain": true,
      "experimental": true,
      "requires_docker": true
    }
  }
}
