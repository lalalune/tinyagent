# ---------------------------------------------------------------------------
# TinyAgent web console — environment
# Copy to `.env.local` for local development.
# ---------------------------------------------------------------------------

# Base URL of the TinyAgent control-plane (the backend). Defaults to localhost:8088.
# The console always talks to this live backend — there is no mock/demo mode.
NEXT_PUBLIC_CONTROL_PLANE_URL=http://localhost:8088

# WalletConnect Cloud project id (optional). RainbowKit works without it for
# injected wallets (MetaMask, Rabby, browser extensions); set it to enable the
# WalletConnect QR / mobile-wallet flow. https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Default chain id the app should expect for on-chain top-ups. The billing
# config endpoint is the source of truth; this is only a UI hint / fallback.
# 31337 = local Anvil/Foundry. 11155111 = Sepolia. 8453 = Base.
NEXT_PUBLIC_DEFAULT_CHAIN_ID=31337
